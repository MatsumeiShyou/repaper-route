{
    "version": "5.0",
    "tierDefinition": {
        "T1": {
            "label": "低リスク（即実行・事後報告）",
            "filePatterns": [
                "*.md",
                "*.json",
                "*.css",
                "*.log",
                "*.txt",
                "docs/**",
                ".vscode/**",
                ".agent/config/**",
                ".agent/workflows/**"
            ],
            "requiresApproval": false,
            "requiresAmplog": false,
            "requiresDebt": false
        },
        "T2": {
            "label": "中リスク（自動検証による自律反復）",
            "filePatterns": [
                "src/**/*.ts",
                "src/**/*.tsx",
                "*.js",
                "tests/**"
            ],
            "requiresApproval": false,
            "requiresAmplog": false,
            "requiresDebt": "conditional",
            "maxRetries": 3
        },
        "T3": {
            "label": "高リスク（フルガバナンス・人間承認必須）",
            "filePatterns": [
                "supabase/migrations/**",
                "AGENTS.md",
                ".agent/scripts/**",
                ".agent/gate/**"
            ],
            "requiresApproval": true,
            "requiresAmplog": true,
            "requiresDebt": true
        }
    },
    "rules": [
        {
            "id": "H-1",
            "name": "Windowsシェル互換性（&&禁止）",
            "section": "AGENTS.md §H",
            "pattern": " && ",
            "include": [
                "package.json",
                ".github/workflows/*.yml"
            ],
            "message": "PowerShell 5.1互換性のため '&&' は使用不可です。';' 等で代替してください。"
        },
        {
            "id": "B-4",
            "name": "AIロジック排除",
            "section": "AGENTS.md §B-4",
            "pattern": "(TODO:|FIXME:).*AI",
            "include": [
                "src/**/*.ts",
                "src/**/*.tsx"
            ],
            "message": "AIによる内部ロジック決定を示唆するTODOは禁止されています。決定論的アルゴリズムを明示してください。"
        },
        {
            "id": "LEGACY",
            "name": "Legacy JS資産の隔離違反",
            "section": "AGENTS.md §H",
            "pattern": "from ['\"].*(src-legacy-js/|Legacy JS).+['\"]",
            "include": [
                "src/**/*.ts",
                "src/**/*.tsx"
            ],
            "message": "Legacy JS資産への直接参照は禁止されています。必要に応じてTSへ移行してください。"
        }
    ],
    "exemptPatterns": [
        "^AMPLOG\\.jsonl$",
        "^GOVERNANCE_REPORT\\.md$",
        "^SCHEMA_HISTORY\\.md$",
        "^DEBT_AND_FUTURE\\.md$",
        "^task\\.md$",
        "^implementation_plan\\.md$",
        "^walkthrough\\.md$",
        "^\\.agent[\\\\/].*\\.md$",
        "^\\.gemini[\\\\/]",
        "^_archived[\\\\/]",
        "\\.test\\.(ts|tsx)$",
        "^vitest\\.config\\.js$",
        "debug_",
        "\\.bak$",
        "\\.tmp$"
    ]
}