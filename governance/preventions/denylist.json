{
    "rules": [
        {
            "id": "root-script-block",
            "pattern": "^test_.*\\.js$|^temp_.*\\.js$",
            "message": "ROOT DIRECTORY ERROR: 検証用スクリプト (*.js) がルートに残っています。物理削除してから反映してください。",
            "include": [
                "./*"
            ]
        },
        {
            "id": "f-ssot-imperative-sync",
            "pattern": "useEffect\\(\\(\\)\\s*=>\\s*\\{[\\s\\n]*set[A-Z][a-zA-Z]*\\(.*\\);?[\\s\\n]*\\},\\s*\\[.*\\]\\)",
            "message": "F-SSOT VIOLATION: useEffect による命令的同期を検知しました。useState + useEffect を廃止し、useMemo による宣言的導出に置き換えてください。",
            "include": [
                "src/**/*.tsx",
                "src/**/*.ts"
            ]
        }
    ]
}