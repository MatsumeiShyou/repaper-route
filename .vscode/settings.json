{
    "accessibility.voice.speechLanguage": "ja-JP",
    "eslint.workingDirectories": [
        { "pattern": "apps/*" },
        { "pattern": "packages/*" }
    ],
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    }
}
